{
  "name": "raff-library",
  "version": "1.1.0",
  "description": "رَفّ - نظام فهرسة وإدارة المكتبات الاحترافي",
  "main": "main.js",
  "author": "Hzifa33",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win --publish never",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.hzifa33.raff",
    "productName": "رَفّ",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "!assets/*-source.*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "رَفّ"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    }
  }
}
